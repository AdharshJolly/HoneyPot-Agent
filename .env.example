# --- Core ---
ENVIRONMENT="development|production"
USE_LLM="true|false"
LLM_BACKEND="local|gemini|openai|disabled"
STRICT_LLM_MODE="true|false"
HONEYPOT_API_KEY="api_key_for_honeypot_service"

# --- Local Ollama ---
OLLAMA_BASE_URL="local_ollama_server_url"
OLLAMA_MODEL="local_ollama_model_name"

# --- External LLMs ---
OPENAI_API_KEY="your_openai_api_key"
GEMINI_API_KEY="your_gemini_api_key"

# --- Callback ---
FINAL_CALLBACK_URL="https://your-callback-endpoint"
CALLBACK_API_KEY="callback_api_key"

# --- Intelligence Export ---
INTEL_EXPORT_ENABLED="true|false"
INTEL_EXPORT_PATH="exports/intel_snapshots.jsonl"
INTEL_EXPORT_MAX_SAMPLES="5"

# --- Server ---
HOST="127.0.0.1"
PORT="8000"
